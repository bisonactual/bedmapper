{
  "productName": "Bedmapper",
  "version": "0.1.0",
  "identifier": "com.bisonactual.bedmapper",
  "build": {
    "frontendDist": "../src-ui/dist",
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "beforeBundleCommand": {
      "script": "sh ../scripts/stage-vision-sidecar.sh"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.png"
    ],
    "resources": [
      "resources/vision"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "Bedmapper",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
